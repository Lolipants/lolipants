# Copy to `.env` in this folder (same directory as pubspec.yaml).
# Flutter loads it at startup via flutter_dotenv.

# Required: Better Auth worker origin (no trailing slash, no /auth path).
# Production (workers.dev): https://lolipants-better-auth.loli-pants.workers.dev
# BETTER_AUTH_BASE_URL=https://lolipants-better-auth.loli-pants.workers.dev
BETTER_AUTH_BASE_URL=

# Optional: Origin header for CORS (defaults to BETTER_AUTH_BASE_URL if unset).
# BETTER_AUTH_ORIGIN=https://lolipants-better-auth.loli-pants.workers.dev

# Main API worker (orders, community, partner intake, etc.) — no trailing slash.
# Must be lolipants-api, NOT the Better Auth URL (wrong host causes 404 on /role-requests).
# Example workers.dev: https://lolipants-api.loli-pants.workers.dev
API_BASE_URL=

# Release payment + push keys for client builds.
# For internal store builds with mock checkout, also pass:
#   --dart-define=FEATURE_MOCK_PAYMENT=true
TAP_PUBLIC_KEY=
ONESIGNAL_APP_ID=

# Web OAuth client ID only — same as Worker secret GOOGLE_CLIENT_ID. Required so
# the ID token `aud` matches Better Auth. Do NOT use iOS or Android client IDs here.
# iOS: GIDClientID + URL scheme live in ios/Runner/Info.plist (Google Cloud iOS client).
# Android: register package + SHA-1 in Cloud Console (Android client); no Android
# client id string is needed in .env for google_sign_in + Better Auth.
GOOGLE_SERVER_CLIENT_ID=

# Optional: R2 public base for media URLs
# CLOUDFLARE_R2_BASE_URL=

# Dev default accounts (see server/lolipants-api/scripts/seed-dev-accounts.ts):
#   admin    lolipants26@gmail.com
#   tailor   lolipants26+tailor@gmail.com
#   driver   lolipants26+driver@gmail.com  (app role: delivery)
# Seed with DEV_SEED_PASSWORD + INTERNAL_SYNC_SECRET in server/lolipants-api.

